# Required: API key for DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=

# Optional: override the model (defaults to deepseek-v4-flash in src/core/llm.ts)
# DEEPSEEK_MODEL=deepseek-chat

# Optional: set to 1 to skip the y/N prompt before shell commands.
# Useful for trusted automation, dangerous otherwise.
# AUTO_APPROVE=1
